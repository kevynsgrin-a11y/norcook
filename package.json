{
  "name": "norcook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check:content": "node scripts/check-content.mjs",
    "check:images": "node scripts/check-image-budgets.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "audit:dependencies": "pnpm audit --audit-level=high",
    "test:e2e": "playwright test",
    "test:performance:mobile": "lhci autorun --config=lighthouserc.mobile.cjs",
    "test:performance:desktop": "lhci autorun --config=lighthouserc.desktop.cjs",
    "release:check": "pnpm lint && pnpm typecheck && pnpm check:content && pnpm check:images && pnpm audit:dependencies && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  }
}
